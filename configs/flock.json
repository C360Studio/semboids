{
  "version": "1.1.0",
  "platform": {
    "org": "c360",
    "id": "semboids",
    "type": "simulation",
    "region": "local",
    "instance_id": "semboids-001",
    "environment": "development"
  },
  "nats": {
    "urls": [
      "nats://localhost:4222"
    ]
  },
  "streams": {
    "ENTITY": {
      "subjects": [
        "entity.>"
      ],
      "storage": "file",
      "max_age": "168h",
      "replicas": 1
    }
  },
  "services": {
    "service-manager": {
      "name": "service-manager",
      "enabled": true,
      "config": {
        "http_port": 8080,
        "swagger_ui": true,
        "server_info": {
          "title": "SemBoids API",
          "description": "Reynolds boids simulator on the SemStreams substrate",
          "version": "0.1.0"
        }
      }
    },
    "component-manager": {
      "name": "component-manager",
      "enabled": true,
      "config": {}
    },
    "metrics": {
      "name": "metrics",
      "enabled": true,
      "config": {
        "port": 9090,
        "path": "/metrics",
        "include_go_metrics": false
      }
    },
    "boids": {
      "name": "boids",
      "enabled": true,
      "config": {}
    }
  },
  "components": {
    "sim": {
      "type": "input",
      "name": "sim",
      "enabled": true,
      "config": {
        "boids": 200,
        "tick_hz": 30,
        "seed": 1,
        "zones": [
          {
            "id": "pred-1",
            "type": "predator",
            "x": 500,
            "y": 450,
            "r": 90,
            "strength": 1.0
          },
          {
            "id": "food-1",
            "type": "food",
            "x": 1150,
            "y": 300,
            "r": 100,
            "strength": 0.6
          },
          {
            "id": "wind-1",
            "type": "wind",
            "x": 800,
            "y": 700,
            "r": 140,
            "strength": 0.4,
            "dx": 1,
            "dy": 0
          }
        ],
        "ports": {
          "inputs": [],
          "outputs": [
            {
              "name": "frames",
              "subject": "boids.frames",
              "type": "nats",
              "required": true
            }
          ]
        },
        "graph_hz": 1,
        "cull_grace_ticks": 90
      }
    },
    "graph-ingest": {
      "type": "processor",
      "name": "graph-ingest",
      "enabled": true,
      "config": {
        "ports": {
          "inputs": [
            {
              "name": "entity_stream",
              "subject": "entity.>",
              "type": "jetstream",
              "stream_name": "ENTITY"
            }
          ],
          "outputs": [
            {
              "name": "entity_states",
              "type": "kv-write",
              "subject": "ENTITY_STATES"
            }
          ]
        }
      }
    },
    "rule-processor": {
      "type": "processor",
      "name": "rule-processor",
      "enabled": true,
      "config": {
        "pack_id": "semboids",
        "rules_files": [
          "configs/rules/zone-steering/predator.json",
          "configs/rules/zone-steering/food.json",
          "configs/rules/zone-steering/wind.json"
        ],
        "enable_graph_integration": false,
        "ports": {
          "inputs": [
            {
              "name": "zone_events",
              "subject": "boids.zone.events",
              "type": "nats",
              "required": true
            }
          ],
          "outputs": [
            {
              "name": "steering",
              "subject": "boids.steering",
              "type": "nats"
            }
          ]
        }
      }
    },
    "frames-websocket": {
      "type": "output",
      "name": "websocket",
      "enabled": true,
      "config": {
        "delivery_mode": "at-most-once",
        "ports": {
          "inputs": [
            {
              "name": "nats_input",
              "subject": "boids.frames",
              "type": "nats",
              "required": true
            }
          ],
          "outputs": [
            {
              "name": "websocket_server",
              "subject": "http://0.0.0.0:8081/ws",
              "type": "network"
            }
          ]
        }
      }
    },
    "graph-index": {
      "type": "processor",
      "name": "graph-index",
      "enabled": true,
      "config": {
        "coalesce_ms": 500,
        "ports": {
          "inputs": [
            {
              "name": "entity_watch",
              "type": "kv-watch",
              "subject": "ENTITY_STATES"
            }
          ],
          "outputs": [
            {
              "name": "outgoing_index",
              "type": "kv-write",
              "subject": "OUTGOING_INDEX"
            },
            {
              "name": "incoming_index",
              "type": "kv-write",
              "subject": "INCOMING_INDEX"
            },
            {
              "name": "alias_index",
              "type": "kv-write",
              "subject": "ALIAS_INDEX"
            },
            {
              "name": "predicate_index",
              "type": "kv-write",
              "subject": "PREDICATE_INDEX"
            }
          ]
        }
      }
    },
    "graph-clustering": {
      "type": "processor",
      "name": "graph-clustering",
      "enabled": true,
      "config": {
        "detection_interval": "2s",
        "batch_size": 50,
        "min_community_size": 3,
        "enable_llm": false,
        "entity_id_edges": {
          "include_siblings": false,
          "include_system_peers": false
        },
        "ports": {
          "inputs": [
            {
              "name": "entity_watch",
              "type": "kv-watch",
              "subject": "ENTITY_STATES"
            }
          ],
          "outputs": [
            {
              "name": "communities",
              "type": "kv-write",
              "subject": "COMMUNITY_INDEX"
            }
          ]
        }
      }
    }
  }
}